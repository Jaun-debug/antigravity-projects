    "content": "<!-- wp:html -->\n<style>\n/* HIDE THE THEME BLUE HEADER ONLY ON THIS PAGE */\n.u-section-1 {\n  display: none !important;\n}\n\n.dt-luxury-grid {\n  display: grid !important;\n  grid-template-columns: repeat(3, 1fr) !important;\n  gap: 30px !important;\n  padding: 40px 0;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n@media (max-width: 900px) {\n  .dt-luxury-grid {\n    grid-template-columns: repeat(2, 1fr) !important;\n  }\n}\n@media (max-width: 600px) {\n  .dt-luxury-grid {\n    grid-template-columns: 1fr !important;\n  }\n}\n.dt-luxury-card {\n  background: #fff;\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.08);\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  display: flex !important;\n  flex-direction: column !important;\n  height: 100% !important;\n}\n.dt-luxury-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 15px 40px rgba(0,0,0,0.12);\n}\n/* TARGET THE ACTUAL IMAGE TAG TO FORCE SIZING */\n.dt-luxury-image {\n  margin: 0 !important;\n  border-bottom: 2px solid #e2a85e;\n}\n.dt-luxury-image img {\n  width: 100% !important;\n  height: 220px !important;\n  object-fit: cover !important;\n  display: block;\n}\n.dt-luxury-content {\n  padding: 25px;\n  display: flex !important;\n  flex-direction: column !important;\n  flex-grow: 1 !important;\n  justify-content: space-between !important;\n}\n.dt-typography-wrap {\n  display: flex;\n  flex-direction: column;\n  flex-grow: 1;\n}\n.dt-luxury-title {\n  font-family: 'Playfair Display', serif;\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1.4;\n  color: #2c3e50;\n  margin-bottom: 15px;\n  text-decoration: none;\n}\n.dt-luxury-title a {\n  color: inherit;\n  text-decoration: none;\n}\n.dt-luxury-title a:hover {\n  color: #e2a85e;\n}\n.dt-luxury-excerpt {\n  font-size: 14px;\n  color: #666;\n  line-height: 1.6;\n  margin-bottom: 20px !important;\n}\n.dt-luxury-btn {\n  display: inline-block;\n  align-self: flex-start;\n  padding: 8px 16px;\n  border: 1px solid #e2a85e;\n  color: #e2a85e;\n  font-size: 13px;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  border-radius: 4px;\n  text-decoration: none;\n  transition: all 0.3s;\n  margin-top: auto !important;\n}\n.dt-luxury-btn:hover {\n  background: #e2a85e;\n  color: #fff;\n}\n</style>\n<!-- /wp:html -->\n\n<!-- wp:query {\"queryId\":0,\"query\":{\"perPage\":21,\"pages\":0,\"offset\":0,\"postType\":\"post\",\"order\":\"desc\",\"orderBy\":\"date\",\"author\":\"\",\"search\":\"\",\"exclude\":[],\"sticky\":\"\",\"inherit\":false}} -->\n<div class=\"wp-block-query\">\n<!-- wp:post-template {\"className\":\"dt-luxury-grid\"} -->\n\n<!-- wp:group {\"className\":\"dt-luxury-card\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-card\">\n\n<!-- wp:post-featured-image {\"isLink\":true,\"className\":\"dt-luxury-image\"} /-->\n\n<!-- wp:group {\"className\":\"dt-luxury-content\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-content\">\n\n<!-- wp:html -->\n<div class=\"dt-typography-wrap\">\n<!-- /wp:html -->\n\n<!-- wp:post-title {\"level\":3,\"isLink\":true,\"className\":\"dt-luxury-title\"} /-->\n\n<!-- wp:post-excerpt {\"moreText\":\"\",\"className\":\"dt-luxury-excerpt\"} /-->\n\n<!-- wp:html -->\n</div>\n<!-- /wp:html -->\n\n<!-- wp:post-title {\"level\":4,\"isLink\":true,\"className\":\"dt-luxury-btn\"} /-->\n\n</div>\n<!-- /wp:group -->\n\n</div>\n<!-- /wp:group -->\n\n<!-- /wp:post-template -->\n\n<!-- wp:query-pagination {\"paginationArrow\":\"arrow\",\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n<!-- wp:query-pagination-previous /-->\n<!-- wp:query-pagination-numbers /-->\n<!-- wp:query-pagination-next /-->\n<!-- /wp:query-pagination -->\n</div>\n<!-- /wp:query -->"
