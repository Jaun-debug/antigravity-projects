    "content": "<!-- wp:html -->\n<style>\n.dt-luxury-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n  gap: 30px;\n  padding: 40px 0;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n.dt-luxury-card {\n  background: #fff;\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.08);\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n}\n.dt-luxury-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 15px 40px rgba(0,0,0,0.12);\n}\n.dt-luxury-image {\n  width: 100%;\n  height: 220px;\n  object-fit: cover;\n  border-bottom: 2px solid #e2a85e;\n}\n.dt-luxury-content {\n  padding: 25px;\n  display: flex;\n  flex-direction: column;\n  flex-grow: 1;\n}\n.dt-luxury-title {\n  font-family: 'Playfair Display', serif;\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1.4;\n  color: #2c3e50;\n  margin-bottom: 15px;\n  text-decoration: none;\n}\n.dt-luxury-title a {\n  color: inherit;\n  text-decoration: none;\n}\n.dt-luxury-title a:hover {\n  color: #e2a85e;\n}\n.dt-luxury-excerpt {\n  font-size: 14px;\n  color: #666;\n  line-height: 1.6;\n  margin-bottom: 20px;\n  flex-grow: 1;\n}\n.dt-luxury-btn {\n  display: inline-block;\n  align-self: flex-start;\n  padding: 8px 16px;\n  border: 1px solid #e2a85e;\n  color: #e2a85e;\n  font-size: 13px;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  border-radius: 4px;\n  text-decoration: none;\n  transition: all 0.3s;\n}\n.dt-luxury-btn:hover {\n  background: #e2a85e;\n  color: #fff;\n}\n</style>\n<!-- /wp:html -->\n\n<!-- wp:query {\"queryId\":0,\"query\":{\"perPage\":20,\"pages\":0,\"offset\":0,\"postType\":\"post\",\"order\":\"desc\",\"orderBy\":\"date\",\"author\":\"\",\"search\":\"\",\"exclude\":[],\"sticky\":\"\",\"inherit\":false},\"displayLayout\":{\"type\":\"flex\",\"columns\":3}} -->\n<div class=\"wp-block-query dt-luxury-grid\">\n<!-- wp:post-template {\"layout\":{\"type\":\"default\"}} -->\n\n<!-- wp:group {\"className\":\"dt-luxury-card\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-card\">\n\n<!-- wp:post-featured-image {\"isLink\":true,\"className\":\"dt-luxury-image\"} /-->\n\n<!-- wp:group {\"className\":\"dt-luxury-content\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-content\">\n\n<!-- wp:post-title {\"level\":3,\"isLink\":true,\"className\":\"dt-luxury-title\"} /-->\n\n<!-- wp:post-excerpt {\"moreText\":\"\",\"className\":\"dt-luxury-excerpt\"} /-->\n\n<!-- wp:html -->\n<div style=\"margin-top:auto\">\n<!-- /wp:html -->\n\n<!-- wp:post-title {\"level\":4,\"isLink\":true,\"className\":\"dt-luxury-btn\"} /-->\n\n<!-- wp:html -->\n</div>\n<!-- /wp:html -->\n\n</div>\n<!-- /wp:group -->\n\n</div>\n<!-- /wp:group -->\n\n<!-- /wp:post-template -->\n\n<!-- wp:query-pagination {\"paginationArrow\":\"arrow\",\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n<!-- wp:query-pagination-previous /-->\n<!-- wp:query-pagination-numbers /-->\n<!-- wp:query-pagination-next /-->\n<!-- /wp:query-pagination -->\n</div>\n<!-- /wp:query -->"
}