    "content": "<!-- wp:html -->\n<style>\n/* HIDE THE THEME BLUE HEADER ONLY ON THIS PAGE */\n.u-section-1 {\n  display: none !important;\n}\n\n/* KILL ALL TRAPPED WHITE SPACE */\n#content, .u-page-root {\n    padding-top: 0 !important;\n    margin-top: 0 !important;\n}\n\n/* HERO SECTION FOR COLLECTION PAGE */\n.dt-collection-hero {\n  position: relative;\n  width: 100vw;\n  margin-left: calc(50% - 50vw);\n  height: 60vh;\n  min-height: 400px;\n  background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.5)), url('https://desert-tracks.com/wp-content/uploads/2025/10/sossusvleipool_220kb-1200x675.jpg');\n  background-size: cover;\n  background-position: center;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-bottom: 50px;\n  \n  /* BRUTE FORCE PULL UP TO HIDE WHITE GAPS */\n  margin-top: -120px !important; \n  padding-top: 120px !important; /* Push text back down so it stays centered */\n\n  color: white;\n  text-align: center;\n}\n.dt-hero-content {\n  position: relative;\n  z-index: 2;\n  padding: 0 20px;\n}\n.dt-hero-title {\n  font-family: 'Playfair Display', serif;\n  font-size: 56px;\n  line-height: 1.2;\n  margin-bottom: 20px;\n  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);\n  color: #ffffff !important;\n}\n.dt-hero-subtitle {\n  font-size: 20px;\n  font-weight: 300;\n  letter-spacing: 1px;\n  text-shadow: 1px 1px 3px rgba(0,0,0,0.3);\n}\n\n.dt-luxury-grid {\n  display: grid !important;\n  grid-template-columns: repeat(3, 1fr) !important;\n  gap: 30px !important;\n  padding: 40px 0;\n  max-width: 1200px;\n  margin: 0 auto;\n}\n@media (max-width: 900px) {\n  .dt-luxury-grid {\n    grid-template-columns: repeat(2, 1fr) !important;\n  }\n  .dt-hero-title {\n    font-size: 40px;\n  }\n}\n@media (max-width: 600px) {\n  .dt-luxury-grid {\n    grid-template-columns: 1fr !important;\n  }\n  .dt-hero-title {\n    font-size: 32px;\n  }\n}\n.dt-luxury-card {\n  background: #fff;\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.08);\n  transition: transform 0.3s ease, box-shadow 0.3s ease;\n  display: flex !important;\n  flex-direction: column !important;\n  height: 100% !important;\n}\n.dt-luxury-card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 15px 40px rgba(0,0,0,0.12);\n}\n.dt-luxury-image {\n  margin: 0 !important;\n  border-bottom: 2px solid #e2a85e;\n}\n.dt-luxury-image img {\n  width: 100% !important;\n  height: 220px !important;\n  object-fit: cover !important;\n  display: block;\n}\n.dt-luxury-content {\n  padding: 25px;\n  display: flex !important;\n  flex-direction: column !important;\n  flex-grow: 1 !important;\n  justify-content: space-between !important;\n}\n.dt-typography-wrap {\n  display: flex;\n  flex-direction: column;\n  flex-grow: 1;\n}\n.dt-luxury-title {\n  font-family: 'Playfair Display', serif;\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1.4;\n  color: #2c3e50;\n  margin-bottom: 15px;\n  text-decoration: none;\n}\n.dt-luxury-title a {\n  color: inherit;\n  text-decoration: none;\n}\n.dt-luxury-title a:hover {\n  color: #e2a85e;\n}\n.dt-luxury-excerpt {\n  font-size: 14px;\n  color: #666;\n  line-height: 1.6;\n  margin-bottom: 20px !important;\n}\n.dt-luxury-btn {\n  display: inline-block;\n  align-self: flex-start;\n  padding: 8px 16px;\n  border: 1px solid #e2a85e;\n  color: #e2a85e;\n  font-size: 13px;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  border-radius: 4px;\n  text-decoration: none;\n  transition: all 0.3s;\n  margin-top: auto !important;\n}\n.dt-luxury-btn:hover {\n  background: #e2a85e;\n  color: #fff;\n}\n\n/* GET RID OF UGLY DEFAULT TITLE ABOVE HERO */\nh1.entry-title,\nheader.entry-header {\n    display: none !important;\n}\n</style>\n\n<div class=\"dt-collection-hero\">\n  <div class=\"dt-hero-content\">\n    <h1 class=\"dt-hero-title\">Namibia Travel & Safari Guides</h1>\n    <p class=\"dt-hero-subtitle\">Expert Advice, Insider Tips, and Inspiration for Your Ultimate Adventure</p>\n  </div>\n</div>\n<!-- /wp:html -->\n\n<!-- wp:query {\"queryId\":0,\"query\":{\"perPage\":21,\"pages\":0,\"offset\":0,\"postType\":\"post\",\"order\":\"desc\",\"orderBy\":\"date\",\"author\":\"\",\"search\":\"\",\"exclude\":[],\"sticky\":\"\",\"inherit\":false}} -->\n<div class=\"wp-block-query\">\n<!-- wp:post-template {\"className\":\"dt-luxury-grid\"} -->\n\n<!-- wp:group {\"className\":\"dt-luxury-card\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-card\">\n\n<!-- wp:post-featured-image {\"isLink\":true,\"className\":\"dt-luxury-image\"} /-->\n\n<!-- wp:group {\"className\":\"dt-luxury-content\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group dt-luxury-content\">\n\n<!-- wp:html -->\n<div class=\"dt-typography-wrap\">\n<!-- /wp:html -->\n\n<!-- wp:post-title {\"level\":3,\"isLink\":true,\"className\":\"dt-luxury-title\"} /-->\n\n<!-- wp:post-excerpt {\"moreText\":\"\",\"className\":\"dt-luxury-excerpt\"} /-->\n\n<!-- wp:html -->\n</div>\n<!-- /wp:html -->\n\n<!-- wp:post-title {\"level\":4,\"isLink\":true,\"className\":\"dt-luxury-btn\"} /-->\n\n</div>\n<!-- /wp:group -->\n\n</div>\n<!-- /wp:group -->\n\n<!-- /wp:post-template -->\n\n<!-- wp:query-pagination {\"paginationArrow\":\"arrow\",\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n<!-- wp:query-pagination-previous /-->\n<!-- wp:query-pagination-numbers /-->\n<!-- wp:query-pagination-next /-->\n<!-- /wp:query-pagination -->\n</div>\n<!-- /wp:query -->"
}